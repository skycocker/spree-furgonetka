<% meta = order.public_metadata.is_a?(Hash) ? order.public_metadata : {} %>
<% code = meta['furgonetka_point'] %>
<% if code.present? %>
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="card-title mb-0">Paczkomat / punkt odbioru</h5>
    </div>
    <div class="card-body">
      <span class="badge badge-info" style="font-size: 1rem;"><%= code %></span>
      <% if meta['furgonetka_point_name'].present? %>
        <div class="mt-2 text-muted"><%= meta['furgonetka_point_name'] %></div>
      <% end %>

      <div class="mt-3">
        <% if meta['furgonetka_tracking'].present? %>
          <div class="text-sm"><%= Spree.t('furgonetka.tracking') %>: <strong><%= meta['furgonetka_tracking'] %></strong></div>
        <% elsif SpreeFurgonetka.config.api_configured? %>
          <% if SpreeFurgonetka.client.connected? %>
            <%= button_to Spree.t('furgonetka.create_label'),
                          spree.admin_furgonetka_create_label_path(order_id: order.number),
                          method: :post, class: 'btn btn-sm btn-primary' %>
          <% else %>
            <%= link_to Spree.t('furgonetka.connect'), spree.admin_furgonetka_connect_path, class: 'btn btn-sm btn-light' %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
